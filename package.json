{
  "name": "wordformatui",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "build:backend": "node scripts/build-backend.cjs",
    "electron:dev": "concurrently -k \"vite --host\" \"wait-on http://localhost:5173 && cross-env VITE_DEV_SERVER_URL=http://localhost:5173 electron .\"",
    "electron:build": "node scripts/build-backend.cjs && vite build && electron-builder",
    "electron:preview": "vite build && electron ."
  },
  "dependencies": {
    "axios": "^1.13.5",
    "js-yaml": "^4.1.1",
    "vue": "^3.5.13"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.2.1",
    "concurrently": "^9.1.0",
    "cross-env": "^7.0.3",
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8",
    "vite": "^6.0.3",
    "wait-on": "^8.0.1"
  },
  "build": {
    "appId": "com.wordformat.app",
    "productName": "WordFormat",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/*.cjs",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "electron/python-runtime",
        "to": "python-runtime",
        "filter": ["**/*"]
      }
    ],
    "mac": {
      "target": ["zip"],
      "icon": "public/icon.png"
    },
    "win": {
      "target": ["nsis", "zip"],
      "icon": "public/icon.png"
    },
    "linux": {
      "target": ["AppImage", "deb"],
      "icon": "public/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
